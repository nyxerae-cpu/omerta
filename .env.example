# OpenRouter proxy (0 EUR setup)
# Copy to .env and fill OPENROUTER_API_KEY.

OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=openrouter/auto:free
OPENROUTER_PROXY_PORT=8787

# Optional metadata for OpenRouter dashboard
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=WorldBuilder Assistant

# Optional: enables protected in-app save/get of proxy OpenRouter settings
OPENROUTER_ADMIN_TOKEN=change-me

# Optional CORS override
OPENROUTER_ALLOW_ORIGIN=*

# Keep responses concise to reduce free quota usage
OPENROUTER_MAX_TOKENS=260
